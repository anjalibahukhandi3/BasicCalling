<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dialPadFragment">

    <fragment
        android:id="@+id/dialPadFragment"
        android:name="com.intern.callingapp.DialPadFragment"
        android:label="DialPadFragment" >
        <action
            android:id="@+id/action_dialPadFragment_to_outgoingCallFragment"
            app:destination="@id/outgoingCallFragment" />
        <action
            android:id="@+id/action_dialPadFragment_to_incomingCallFragment"
            app:destination="@id/incomingCallFragment" />
    </fragment>
    
    <fragment
        android:id="@+id/outgoingCallFragment"
        android:name="com.intern.callingapp.OutgoingCallFragment"
        android:label="OutgoingCallFragment" >
        <argument
            android:name="number"
            app:argType="string" />
        <action
            android:id="@+id/action_outgoingCallFragment_to_activeCallFragment"
            app:destination="@id/activeCallFragment"
            app:popUpTo="@id/dialPadFragment" />
        <action
            android:id="@+id/action_outgoingCallFragment_to_dialPadFragment"
            app:destination="@id/dialPadFragment"
            app:popUpTo="@id/dialPadFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/incomingCallFragment"
        android:name="com.intern.callingapp.IncomingCallFragment"
        android:label="IncomingCallFragment" >
        <argument
            android:name="callerName"
            app:argType="string" />
        <action
            android:id="@+id/action_incomingCallFragment_to_activeCallFragment"
            app:destination="@id/activeCallFragment"
            app:popUpTo="@id/dialPadFragment" />
        <action
            android:id="@+id/action_incomingCallFragment_to_dialPadFragment"
            app:destination="@id/dialPadFragment"
            app:popUpTo="@id/dialPadFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/activeCallFragment"
        android:name="com.intern.callingapp.ActiveCallFragment"
        android:label="ActiveCallFragment" >
        <action
            android:id="@+id/action_activeCallFragment_to_dialPadFragment"
            app:destination="@id/dialPadFragment"
            app:popUpTo="@id/dialPadFragment"
            app:popUpToInclusive="true" />
    </fragment>
</navigation>
